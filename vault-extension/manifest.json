{
  "manifest_version": 3,
  "name": "Vault Resell Sync",
  "version": "1.2.0",
  "description": "Sync Vinted bestellingen naar Vault Resell tracker",
  "permissions": ["storage", "activeTab", "downloads"],
  "host_permissions": [
    "https://*.vinted.be/*",
    "https://*.vinted.com/*",
    "https://*.vinted.nl/*",
    "https://dusffpxcheojvjwuqgwo.supabase.co/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vault Resell Sync"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vinted.be/*",
        "https://*.vinted.com/*",
        "https://*.vinted.nl/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
